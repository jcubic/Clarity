<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clarity Icon Theme</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: system-ui, sans-serif;
            background: oklch(14% 0.012 245);
            color: oklch(96% 0.005 245);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            background: oklch(20% 0.015 245);
            border: 1px solid oklch(30% 0.02 245);
            border-radius: 14px;
            padding: 2.5rem;
            max-width: 480px;
            width: 90%;
        }
        h1 {
            font-size: 1.75rem;
            margin-bottom: 0.25rem;
            color: oklch(72% 0.16 230);
        }
        .tagline {
            color: oklch(65% 0.01 245);
            margin-bottom: 1.5rem;
        }
        .info {
            font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
            font-size: 0.85rem;
            background: oklch(12% 0.01 245);
            border-radius: 8px;
            padding: 1rem;
        }
        .info dt {
            color: oklch(55% 0.01 245);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 0.75rem;
        }
        .info dt:first-child { margin-top: 0; }
        .info dd {
            color: oklch(72% 0.16 230);
            margin-top: 0.15rem;
        }
        .check {
            color: oklch(72% 0.18 145);
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>Clarity</h1>
        <p class="tagline">Slim + Twig deployment test</p>
        <dl class="info">
            <dt>Framework</dt>
            <dd>Slim {{ slim_version }}</dd>
            <dt>Template</dt>
            <dd>Twig {{ twig_version }}</dd>
            <dt>PHP</dt>
            <dd>{{ php_version }}</dd>
            <dt>Status</dt>
            <dd class="check">&#10003; All systems operational</dd>
        </dl>
    </div>
</body>
</html>
