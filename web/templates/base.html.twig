<!doctype html>
<html lang="en" class="no-js">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% block title %}Clarity — A GTK+ Icon Theme in Nine Colors{% endblock %}</title>
  <meta name="description" content="{% block description %}1,000 unique icons for your GTK desktop, hand-tuned across thirteen color variants. One curl, you're done.{% endblock %}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{% block og_title %}Clarity — A GTK+ Icon Theme in Nine Colors{% endblock %}" />
  <meta property="og:description" content="{% block og_description %}1,000 unique icons for your GTK desktop, hand-tuned across thirteen color variants. One curl, you're done.{% endblock %}" />
  <meta property="og:image" content="https://clarity.pl.eu.org/clarity-social-card.png" />
  <meta property="og:url" content="https://clarity.pl.eu.org/" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Clarity — A GTK+ Icon Theme in Nine Colors" />
  <meta name="twitter:description" content="1,000 unique icons for your GTK desktop, hand-tuned across thirteen color variants. One curl, you're done." />
  <meta name="twitter:image" content="https://clarity.pl.eu.org/clarity-social-card.png" />
  <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
  <link rel="shortcut icon" href="/favicon/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Clarity Icons" />
  <link rel="manifest" href="/favicon/site.webmanifest" />
  <link rel="stylesheet" href="{{ '/css/style.css' | with_hash }}" />
  <script>document.documentElement.classList.remove('no-js'); document.documentElement.classList.add('js');</script>
</head>

<body>
  {% include 'components/svg-symbols.html.twig' %}
  {% include 'components/header.html.twig' %}

  <main id="top"{% block main_attrs %}{% endblock %}>
    {% block content %}{% endblock %}
  </main>

  {% include 'components/footer.html.twig' %}
  <script src="{{ '/js/main.js' | with_hash }}"></script>
</body>
</html>
