<section class="variants" id="variants" aria-labelledby="variants-heading">
  <div class="container">
    <header class="section-header">
      <p class="section-eyebrow">// 02 — Five flavors</p>
      <h2 id="variants-heading" class="section-title">Pick your accent. Or wear all five.</h2>
      <p class="section-lead">Every icon ships in five carefully tuned palettes — named after their Latin colors. Switch with a single click; no rebuild, no recompile.</p>
    </header>

    <div class="variant-tabs" id="variant-tabs">
      <div class="variant-tabbar" role="tablist" aria-label="Color variants">
        {% for variant in variants %}
        <button class="variant-tab variant-tab--{{ variant.id }}{% if loop.first %} is-active{% endif %}" type="button" role="tab" data-tab="{{ variant.id }}" aria-selected="{{ loop.first ? 'true' : 'false' }}" aria-controls="vp-{{ variant.id }}" id="vt-{{ variant.id }}"><span class="variant-dot" aria-hidden="true"></span><span>{{ variant.name }}</span><span class="variant-count">{{ icons|length }}</span></button>
        {% endfor %}
      </div>

      {% for variant in variants %}
      <section class="variant-panel variant-panel--{{ variant.id }}" id="vp-{{ variant.id }}" data-tab-panel="{{ variant.id }}" role="tabpanel" aria-labelledby="vt-{{ variant.id }}">
        <header class="variant-panel-head">
          <h3 class="variant-panel-name"><span class="variant-dot" aria-hidden="true"></span>{{ variant.name }}</h3>
          <p class="variant-panel-latin">{{ variant.latin }}</p>
          <p class="variant-panel-token"><span class="key">oklch</span>{{ variant.oklch }}</p>
        </header>
        <ul class="icon-grid">
          {% for icon in icons %}
          <li class="icon-tile"><svg viewBox="0 0 24 24" aria-label="{{ icon.label }}"><use href="#i-{{ icon.id }}"/></svg><span class="icon-tile-name">{{ icon.name }}</span></li>
          {% endfor %}
        </ul>
      </section>
      {% endfor %}
    </div>
  </div>
</section>
